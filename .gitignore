# 🔒 SEGURANÇA — Nunca commitar
.env
.env.local
.env.*.local
config.json
*.key
*.pem
secrets.txt
secrets/

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.pytest_cache/
.mypy_cache/

# Ambientes virtuais
.venv/
venv/
env/
ENV/
.virtualenv/

# Build & dist
*.egg-info/
dist/
build/
*.egg
MANIFEST

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Logs
*.log
logs/
npm-debug.log*

# Testing
.coverage
htmlcov/
.tox/
coverage.xml
*.cover

# Vercel
.vercel/

# Distribuição local (o ZIP é gerado pelo GitHub Release)
*.zip
