{
  "version": 2,
  "builds": [
    {
      "src": "api/chat.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/health",
      "dest": "api/chat.py"
    },
    {
      "src": "/chat",
      "dest": "api/chat.py"
    },
    {
      "src": "/(.*)",
      "dest": "api/chat.py"
    }
  ]
}
