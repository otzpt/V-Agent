# ──────────────────────────────────────────────────────────────
# V-Agent — Environment Variables Template
# ──────────────────────────────────────────────────────────────
# INSTRUCOES:
#   1. Copia este ficheiro para .env
#   2. Preenche apenas se quiseres correr o backend LOCAL
#   3. Em produção, as keys ficam no Vercel (não aqui)
#
# ⚠️  NUNCA commitar o .env com valores reais no GitHub!
# ──────────────────────────────────────────────────────────────

# ── Backend URL ───────────────────────────────────────────────
# URL do backend Vercel (deixa em branco para usar o oficial)
VAGENT_SERVER_URL=https://vt-inference-relay.vercel.app

# ── Apenas para desenvolvimento local do backend ──────────────
# Se quiseres correr api/chat.py localmente, preenche aqui.
# Em produção isto é configurado no Vercel, nunca aqui.
GROQ_API_KEY=

# ── Config do V-Agent (opcional) ─────────────────────────────
# Provider: backend (recomendado) | groq | openrouter | local
VAGENT_PROVIDER=backend
VAGENT_MODEL=llama-3.3-70b-versatile
